{
  "name": "@shadowob/connector",
  "version": "1.1.58",
  "description": "Shadow connector helpers for OpenClaw, Hermes Agent, and cc-connect",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "require": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "shadowob-connector": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "development": "./src/browser.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs",
      "default": "./dist/browser.js"
    },
    "./runtime-sessions": {
      "types": "./dist/runtime-sessions.d.ts",
      "development": "./src/runtime-sessions.ts",
      "import": "./dist/runtime-sessions.js",
      "require": "./dist/runtime-sessions.cjs",
      "default": "./dist/runtime-sessions.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "hermes-shadowob-plugin/__init__.py",
    "hermes-shadowob-plugin/adapter.py",
    "hermes-shadowob-plugin/plugin.yaml",
    "hermes-shadowob-plugin/README.md",
    "hermes-shadowob-plugin/requirements.txt",
    "hermes-shadowob-plugin/shadow_sdk.py",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "shadow",
    "shadowob",
    "openclaw",
    "hermes-agent",
    "cc-connect",
    "connector"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buggyblues/shadow",
    "directory": "packages/connector"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@shadowob/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "smol-toml": "^1.6.1",
    "yaml": "^2.8.4"
  }
}

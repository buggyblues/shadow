{
  "name": "@shadowob/sdk",
  "version": "1.1.67",
  "description": "Shadow SDK — typed REST client and real-time Socket.IO event listener for Shadow servers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "require": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "shadow-space-app": "./bin/shadow-space-app.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./space-app/node": {
      "types": "./dist/space-app-node.d.ts",
      "development": "./src/space-app-node.ts",
      "import": "./dist/space-app-node.js",
      "require": "./dist/space-app-node.cjs",
      "default": "./dist/space-app-node.js"
    },
    "./space-app": {
      "types": "./dist/space-app.d.ts",
      "development": "./src/space-app.ts",
      "import": "./dist/space-app.js",
      "require": "./dist/space-app.cjs",
      "default": "./dist/space-app.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "development": "./src/bridge.ts",
      "react-native": "./src/bridge.ts",
      "import": "./dist/bridge.js",
      "require": "./dist/bridge.cjs",
      "default": "./dist/bridge.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@shadowob/shared": "workspace:*",
    "socket.io-client": "^4.8.1"
  },
  "peerDependencies": {
    "agora-rtc-sdk-ng": "^4.24.3"
  },
  "peerDependenciesMeta": {
    "agora-rtc-sdk-ng": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "agora-rtc-sdk-ng": "^4.24.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@shadowob/sdk",
  "version": "1.1.5",
  "description": "Shadow SDK — typed REST client and real-time Socket.IO event listener for Shadow servers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "require": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@shadowob/shared": "workspace:*",
    "socket.io-client": "^4.8.1"
  },
  "peerDependencies": {
    "agora-rtc-sdk-ng": "^4.24.3"
  },
  "peerDependenciesMeta": {
    "agora-rtc-sdk-ng": {
      "optional": true
    }
  },
  "devDependencies": {
    "agora-rtc-sdk-ng": "^4.24.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}

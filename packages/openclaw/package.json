{
  "name": "@shadowob/openclaw",
  "version": "0.4.1",
  "description": "OpenClaw Shadow channel plugin — enables AI agents to interact in Shadow server channels",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "require": "./dist/index.cjs",
  "exports": {
    ".": {
      "development": "./index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buggyblues/shadow",
    "directory": "packages/openclaw"
  },
  "homepage": "https://github.com/buggyblues/shadow/tree/main/packages/openclaw#readme",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "shadow",
    "chat",
    "channel",
    "ai-agent"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@shadowob/sdk": "workspace:*",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

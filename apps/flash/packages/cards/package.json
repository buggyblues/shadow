{
  "name": "@shadowob/flash-cards",
  "version": "1.0.0",
  "description": "Flash — ECS-based card rendering engine with plugin architecture",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "require": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.cjs",
      "default": "./dist/plugins/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@shadowob/flash-types": "workspace:*",
    "bitecs": "^0.4.0",
    "matter-js": "^0.20.0",
    "katex": "^0.16.45",
    "lottie-web": "^5.13.0",
    "three": "^0.183.2",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.4.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/matter-js": "^0.20.2",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.183.1",
    "@types/katex": "^0.16.8",
    "@webgpu/types": "^0.1.69",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}

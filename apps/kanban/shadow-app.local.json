{
  "schemaVersion": "shadow.app/1",
  "appKey": "shadow-kanban",
  "name": "Shadow Kanban",
  "description": "A Trello-style task board where people and Buddies coordinate cards, lists, assignees, and comments.",
  "version": "1.0.0",
  "iconUrl": "http://localhost:4201/assets/icon.svg",
  "iframe": {
    "entry": "http://localhost:4201/shadow/server",
    "allowedOrigins": ["http://localhost:4201"]
  },
  "api": {
    "baseUrl": "http://localhost:4201",
    "auth": { "type": "oauth2-bearer" }
  },
  "access": {
    "defaultPermissions": ["kanban.boards:read"],
    "defaultApprovalMode": "none"
  },
  "commands": [
    {
      "name": "boards.get",
      "title": "Open board",
      "description": "Read the current task board with columns and cards.",
      "path": "/api/shadow/commands/boards.get",
      "permission": "kanban.boards:read",
      "action": "read",
      "dataClass": "server-private"
    },
    {
      "name": "cards.create",
      "title": "Create card",
      "description": "Create a new task card in a board column.",
      "path": "/api/shadow/commands/cards.create",
      "permission": "kanban.cards:write",
      "action": "write",
      "dataClass": "server-private",
      "approvalMode": "first_time",
      "inputSchema": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "columnId": { "type": "string" },
          "description": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    },
    {
      "name": "cards.move",
      "title": "Move card",
      "description": "Move a card to another column.",
      "path": "/api/shadow/commands/cards.move",
      "permission": "kanban.cards:write",
      "action": "write",
      "dataClass": "server-private",
      "approvalMode": "first_time",
      "inputSchema": {
        "type": "object",
        "required": ["cardId", "columnId"],
        "properties": {
          "cardId": { "type": "string" },
          "columnId": { "type": "string" }
        }
      }
    },
    {
      "name": "cards.assign",
      "title": "Assign card",
      "description": "Assign a person or Buddy label to a task card.",
      "path": "/api/shadow/commands/cards.assign",
      "permission": "kanban.cards:write",
      "action": "write",
      "dataClass": "server-private",
      "approvalMode": "first_time",
      "inputSchema": {
        "type": "object",
        "required": ["cardId", "assignee"],
        "properties": {
          "cardId": { "type": "string" },
          "assignee": { "type": "string" }
        }
      }
    },
    {
      "name": "cards.comment",
      "title": "Comment on card",
      "description": "Add a short update comment to a task card.",
      "path": "/api/shadow/commands/cards.comment",
      "permission": "kanban.cards:write",
      "action": "write",
      "dataClass": "server-private",
      "approvalMode": "first_time",
      "inputSchema": {
        "type": "object",
        "required": ["cardId", "body"],
        "properties": {
          "cardId": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    }
  ],
  "skills": [
    {
      "name": "shadow-kanban-board-ops",
      "description": "Use when a Buddy needs to read, create, move, assign, or comment on Shadow Kanban task cards.",
      "commandHints": [
        "shadow-kanban boards.get",
        "shadow-kanban cards.create",
        "shadow-kanban cards.move",
        "shadow-kanban cards.assign",
        "shadow-kanban cards.comment"
      ]
    }
  ],
  "events": ["board.updated"]
}

{
  "name": "@shadowob/desktop",
  "productName": "Shadow",
  "version": "0.2.1",
  "private": true,
  "description": "Shadow Desktop - Native desktop client",
  "author": "ShadowOB Team",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "start": "electron-forge start",
    "package": "pnpm build && electron-forge package",
    "make": "pnpm build && electron-forge make",
    "release": "node scripts/release.mjs --platform=all --mode=make",
    "release:mac:x64": "node scripts/release.mjs --platform=darwin --arch=x64 --mode=make --notarize",
    "release:mac:arm64": "node scripts/release.mjs --platform=darwin --arch=arm64 --mode=make --notarize",
    "release:win": "node scripts/release.mjs --platform=win32 --arch=x64 --mode=make",
    "release:linux": "node scripts/release.mjs --platform=linux --arch=x64 --mode=make",
    "changelog:archive": "node scripts/archive-changelog.mjs",
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@shadowob/shared": "workspace:*",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@playwright/test": "^1.52.0",
    "@rsbuild/core": "^1.3.21",
    "@rsbuild/plugin-react": "^1.4.6",
    "@rspack/cli": "^1.7.9",
    "@rspack/core": "^1.7.9",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-router": "^1.121.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.17",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.2",
    "electron": "41.0.3",
    "i18next": "^25.8.14",
    "lucide-react": "^0.577.0",
    "openclaw": "^2026.3.13",
    "playwright": "^1.52.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}

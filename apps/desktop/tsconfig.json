{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@web/*": ["../web/src/*"],
      "@shadowob/cloud-ui/components/*": ["../cloud/packages/ui/src/components/*"],
      "@shadowob/cloud-ui/lib/*": ["../cloud/packages/ui/src/lib/*"],
      "@shadowob/cloud-ui/web-saas": ["../web/src/types/cloud-ui.d.ts"]
    },
    "rootDirs": ["./src", "../web/src"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules", ".rspack", "out"]
}

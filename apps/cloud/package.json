{
  "name": "@shadowob/cloud",
  "version": "1.0.0",
  "description": "shadowob-cloud — deploy AI agents to Kubernetes",
  "type": "module",
  "bin": {
    "shadowob-cloud": "./dist/index.js"
  },
  "files": [
    "dist",
    "images",
    "templates"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && rsbuild build",
    "dev": "tsup --watch",
    "console:dev": "rsbuild dev",
    "console:build": "rsbuild build",
    "console:preview": "rsbuild preview",
    "generate:schema": "node --import tsx scripts/generate-schema.ts",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.dashboard.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:cli": "vitest run --config vitest.cli.config.ts",
    "test:e2e:console": "playwright test",
    "test:e2e:console:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.5.0",
    "@monaco-editor/react": "^4.7.0",
    "@pulumi/kubernetes": "^4.21.0",
    "@pulumi/pulumi": "^3.160.0",
    "@shadowob/sdk": "workspace:*",
    "@shadowob/shared": "workspace:*",
    "@shadowob/ui": "workspace:*",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-router": "^1.168.2",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "clsx": "^2.1.1",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.8",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.513.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "tailwind-merge": "^3.3.0",
    "typia": "^12.0.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@rsbuild/core": "^1.3.21",
    "@rsbuild/plugin-react": "^1.4.6",
    "@standard-schema/spec": "^1.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@typia/unplugin": "^12.0.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "ts-patch": "^3.3.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.67.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}

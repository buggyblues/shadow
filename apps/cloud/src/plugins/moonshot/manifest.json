{
  "id": "moonshot",
  "name": "Moonshot Kimi",
  "description": "Connect agents to Moonshot Kimi models through the OpenAI-compatible API",
  "version": "1.0.0",
  "category": "ai-provider",
  "icon": "brain",
  "website": "https://kimi.moonshot.cn",
  "docs": "https://platform.moonshot.cn/docs",
  "auth": {
    "type": "api-key",
    "fields": [
      {
        "key": "MOONSHOT_API_KEY",
        "label": "API Key",
        "description": "Moonshot API key",
        "required": true,
        "sensitive": true,
        "placeholder": "sk-..."
      }
    ]
  },
  "config": {
    "type": "object",
    "properties": {
      "defaultModel": {
        "type": "string",
        "default": "moonshot-v1-32k",
        "description": "Default Moonshot model"
      },
      "baseUrl": {
        "type": "string",
        "default": "https://api.moonshot.ai/v1",
        "description": "Moonshot OpenAI-compatible base URL"
      }
    }
  },
  "capabilities": ["auth-provider"],
  "tags": ["ai", "llm", "kimi", "moonshot", "openai-compatible"],
  "popularity": 71
}

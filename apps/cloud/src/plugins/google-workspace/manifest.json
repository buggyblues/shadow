{
  "id": "google-workspace",
  "name": "Google Workspace",
  "description": "Connect agents to Gmail, Calendar, Drive, Docs, Sheets, Chat, Admin, and other Workspace APIs through the gws CLI and its agent skills",
  "version": "1.0.0",
  "category": "productivity",
  "icon": "google",
  "website": "https://github.com/googleworkspace/cli",
  "docs": "https://github.com/googleworkspace/cli#authentication",
  "auth": {
    "type": "oauth2",
    "fields": [
      {
        "key": "GOOGLE_WORKSPACE_CLI_CREDENTIALS_JSON",
        "label": "Google Workspace credentials.json",
        "description": "Paste credentials.json from `gws auth export --unmasked`, or a service-account JSON.",
        "required": false,
        "sensitive": true,
        "placeholder": "{\"installed\":{\"client_id\":\"...\"}}"
      },
      {
        "key": "GOOGLE_WORKSPACE_CLI_TOKEN",
        "label": "Google Workspace access token",
        "description": "Optional pre-obtained OAuth2 access token. The account authorization flow fills this automatically.",
        "required": false,
        "sensitive": true,
        "placeholder": "ya29..."
      }
    ],
    "oauth": {
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "pkce": true,
      "accessTokenField": "GOOGLE_WORKSPACE_CLI_TOKEN",
      "authorizationParams": {
        "access_type": "offline",
        "prompt": "consent"
      },
      "scopes": [
        "openid",
        "email",
        "https://www.googleapis.com/auth/drive",
        "https://www.googleapis.com/auth/gmail.modify",
        "https://www.googleapis.com/auth/calendar",
        "https://www.googleapis.com/auth/documents",
        "https://www.googleapis.com/auth/spreadsheets"
      ]
    }
  },
  "config": {
    "type": "object",
    "properties": {
      "services": {
        "type": "array",
        "description": "Workspace services this Buddy should prefer, such as gmail, calendar, drive, docs, sheets, chat, or admin.",
        "items": { "type": "string" },
        "default": ["gmail", "calendar", "drive", "docs", "sheets"]
      },
      "readOnlyByDefault": {
        "type": "boolean",
        "description": "Require explicit user approval before create, update, send, or delete actions.",
        "default": true
      }
    }
  },
  "capabilities": ["tool", "data-source", "action", "skill", "cli"],
  "tags": [
    "google",
    "workspace",
    "gmail",
    "calendar",
    "drive",
    "docs",
    "sheets",
    "chat",
    "admin",
    "cli"
  ],
  "popularity": 94
}

{
  "version": "1",
  "name": "managed-agents-demo",
  "title": "${i18n:title}",
  "description": "${i18n:description}",
  "environment": "development",
  "$comment": "Template with managed-agents features: vault isolation, permissions, networking, versioning",
  "registry": {
    "vaults": {
      "default": {
        "providers": {
          "anthropic": {
            "apiKey": "${env:ANTHROPIC_API_KEY}"
          },
          "openai": {
            "apiKey": "${env:OPENAI_API_KEY}"
          }
        },
        "secrets": {
          "github-token": "${env:GITHUB_TOKEN}"
        }
      },
      "restricted": {
        "providers": {
          "anthropic": {
            "apiKey": "${env:RESTRICTED_ANTHROPIC_KEY}"
          }
        }
      }
    }
  },
  "deployments": {
    "namespace": "managed-agents-demo",
    "agents": [
      {
        "id": "code-assistant",
        "runtime": "claude-code",
        "version": "1.0.0",
        "changelog": "Initial release with coding assistance",
        "vault": "default",
        "configuration": {},
        "permissions": {
          "default": "approve-reads",
          "tools": {
            "bash": "always-ask",
            "file-write": "approve-reads",
            "web-fetch": "always-allow",
            "mcp-*": "always-ask"
          },
          "nonInteractive": "deny"
        },
        "networking": {
          "type": "limited",
          "allowedHosts": ["api.anthropic.com", "api.github.com"],
          "allowMcpServers": true,
          "allowPackageManagers": false
        },
        "identity": {
          "name": "Code Assistant",
          "personality": "You are a careful, security-conscious code reviewer.",
          "systemPrompt": "Help users write clean, tested, and secure code."
        },
        "description": "Code assistant with restricted permissions and vault isolation"
      },
      {
        "id": "researcher",
        "runtime": "openclaw",
        "version": "2.1.0",
        "changelog": "Added web search capabilities",
        "vault": "restricted",
        "configuration": {},
        "permissions": {
          "default": "always-allow",
          "tools": {
            "bash": "deny-all",
            "file-write": "deny-all"
          }
        },
        "networking": {
          "type": "unrestricted"
        },
        "identity": {
          "name": "Researcher",
          "systemPrompt": "Research topics and provide summaries."
        },
        "description": "Research agent with unrestricted networking but no filesystem access",
        "use": [
          {
            "plugin": "model-provider",
            "options": {
              "tag": "reasoning"
            }
          }
        ]
      },
      {
        "id": "sandboxed-runner",
        "runtime": "openclaw",
        "version": "0.5.0",
        "configuration": {},
        "permissions": {
          "default": "deny-all"
        },
        "networking": {
          "type": "deny-all"
        },
        "description": "Fully sandboxed agent — no network, no tools",
        "use": [
          {
            "plugin": "model-provider",
            "options": {
              "tag": "flash"
            }
          }
        ]
      }
    ]
  },
  "use": [
    {
      "plugin": "model-provider"
    }
  ],
  "i18n": {
    "en": {
      "title": "Managed Agents Demo",
      "description": "Evaluate safer managed-agent operations with a demo team that showcases vault isolation, permission boundaries, network controls, and sandboxed runtimes before customers roll them into production."
    },
    "zh-CN": {
      "title": "托管智能体演示",
      "description": "通过演示团队评估更安全的托管智能体运行方式，展示 vault 隔离、权限边界、网络控制和沙箱运行时，便于客户在生产落地前完成验证。"
    }
  }
}

{
  "version": "1",
  "environment": "development",
  "use": [
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "template-hub",
            "name": "Template Discovery Hub",
            "slug": "template-hub",
            "channels": [
              { "id": "discover", "title": "Discover Templates", "type": "text" },
              { "id": "deploy-guide", "title": "Deployment Guide", "type": "text" },
              { "id": "status", "title": "Status", "type": "text" }
            ]
          }
        ],
        "buddies": [
          { "id": "scout-bot", "name": "Template Scout" },
          { "id": "advisor-bot", "name": "Template Advisor" },
          { "id": "mentor-bot", "name": "Deploy Mentor" }
        ],
        "bindings": [
          {
            "targetId": "scout-bot",
            "targetType": "buddy",
            "servers": ["template-hub"],
            "channels": ["discover", "status"],
            "agentId": "template-scout",
            "replyPolicy": { "mode": "mentionOnly" }
          },
          {
            "targetId": "advisor-bot",
            "targetType": "buddy",
            "servers": ["template-hub"],
            "channels": ["discover"],
            "agentId": "template-advisor",
            "replyPolicy": { "mode": "replyAll" }
          },
          {
            "targetId": "mentor-bot",
            "targetType": "buddy",
            "servers": ["template-hub"],
            "channels": ["deploy-guide"],
            "agentId": "deploy-mentor",
            "replyPolicy": { "mode": "replyAll" }
          }
        ]
      }
    }
  ],
  "registry": {
    "providers": [
      {
        "id": "deepseek",
        "api": "openai",
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "${env:DEEPSEEK_API_KEY}",
        "models": [
          { "id": "deepseek-chat", "contextWindow": 65536 },
          { "id": "deepseek-reasoner", "contextWindow": 65536 }
        ]
      }
    ],
    "configurations": [
      {
        "id": "discovery-base",
        "model": { "preferred": "deepseek/deepseek-chat" },
        "openclaw": {
          "tools": {
            "profile": "messaging",
            "web": { "fetch": { "enabled": true } }
          },
          "session": { "dmScope": "per-peer" },
          "messages": {
            "ackReaction": "🔍",
            "ackReactionScope": "all",
            "removeAckAfterReply": true
          }
        }
      },
      {
        "id": "advisor-config",
        "extends": "discovery-base",
        "model": {
          "preferred": "deepseek/deepseek-reasoner",
          "fallbacks": ["deepseek/deepseek-chat"]
        }
      },
      {
        "id": "mentor-config",
        "extends": "discovery-base",
        "openclaw": {
          "messages": { "ackReaction": "📦" }
        }
      }
    ]
  },
  "deployments": {
    "namespace": "template-discovery",
    "agents": [
      {
        "id": "template-scout",
        "runtime": "openclaw",
        "description": "Searches the Shadow community template store via the server API.",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "path": "./agents/template-scout",
              "git": {
                "url": "https://github.com/shadowob/template-discovery-team",
                "ref": "main",
                "dir": "agents/template-scout"
              }
            }
          }
        ],
        "configuration": { "extends": "discovery-base" },
        "resources": {
          "requests": { "cpu": "100m", "memory": "256Mi" },
          "limits": { "cpu": "500m", "memory": "512Mi" }
        }
      },
      {
        "id": "template-advisor",
        "runtime": "openclaw",
        "description": "Matches templates to user requirements and recommends the best fit.",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "path": "./agents/template-advisor",
              "git": {
                "url": "https://github.com/shadowob/template-discovery-team",
                "ref": "main",
                "dir": "agents/template-advisor"
              }
            }
          }
        ],
        "configuration": { "extends": "advisor-config" },
        "resources": {
          "requests": { "cpu": "200m", "memory": "512Mi" },
          "limits": { "cpu": "1000m", "memory": "1Gi" }
        }
      },
      {
        "id": "deploy-mentor",
        "runtime": "openclaw",
        "description": "Guides users step-by-step through local or cloud deployment of a chosen template.",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "path": "./agents/deploy-mentor",
              "git": {
                "url": "https://github.com/shadowob/template-discovery-team",
                "ref": "main",
                "dir": "agents/deploy-mentor"
              }
            }
          }
        ],
        "configuration": { "extends": "mentor-config" },
        "resources": {
          "requests": { "cpu": "200m", "memory": "512Mi" },
          "limits": { "cpu": "1000m", "memory": "1Gi" }
        }
      }
    ]
  }
}

{
  "version": "1.0.0",
  "name": "${i18n:name}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "my-server",
            "name": "My Shadow Server",
            "channels": [
              {
                "id": "general",
                "title": "General"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "my-buddy",
            "name": "My AI Assistant"
          }
        ],
        "bindings": [
          {
            "targetId": "my-buddy",
            "targetType": "buddy",
            "servers": ["my-server"],
            "channels": ["general"],
            "agentId": "my-agent"
          }
        ]
      }
    }
  ],
  "registry": {
    "providers": [
      {
        "id": "openai",
        "api": "openai",
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${env:OPENAI_API_KEY}",
        "models": [
          {
            "id": "gpt-4o-mini",
            "labels": ["fast", "chat"]
          },
          {
            "id": "gpt-4o",
            "labels": ["reasoning"]
          }
        ]
      },
      {
        "id": "deepseek",
        "api": "openai",
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "${env:DEEPSEEK_API_KEY}",
        "models": [
          {
            "id": "deepseek-chat",
            "contextWindow": 65536
          },
          {
            "id": "deepseek-reasoner",
            "contextWindow": 65536
          }
        ]
      }
    ],
    "configurations": [
      {
        "id": "base-chat",
        "openclaw": {
          "policies": {
            "maxTokensPerResponse": 1024,
            "timeoutSeconds": 30
          }
        }
      }
    ]
  },
  "deployments": {
    "namespace": "shadowob-cloud",
    "agents": [
      {
        "id": "my-agent",
        "runtime": "openclaw",
        "model": {
          "preferred": "openai/gpt-4o-mini",
          "fallbacks": ["deepseek/deepseek-chat"]
        },
        "configuration": {
          "extends": "base-chat",
          "openclaw": {
            "systemPrompt": "You are a helpful AI assistant.",
            "tools": {
              "profile": "full",
              "web": {
                "search": {
                  "enabled": true
                },
                "fetch": {
                  "enabled": true
                }
              }
            }
          }
        }
      }
    ]
  },
  "i18n": {
    "en": {
      "name": "Shadow Cloud Basic",
      "description": "Basic single-agent template with a general AI assistant. Quick-start template for Shadow Cloud deployment."
    },
    "zh-CN": {
      "name": "Shadow Cloud 基础版",
      "description": "基础单智能体模板，包含一个通用 AI 助手。适用于 Shadow Cloud 快速部署。"
    }
  }
}

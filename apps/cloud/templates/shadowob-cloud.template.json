{
  "version": "1.0.0",
  "name": "${i18n:name}",
  "description": "${i18n:description}",
  "environment": "production",
  "use": [
    {
      "plugin": "model-provider"
    },
    {
      "plugin": "shadowob",
      "options": {
        "servers": [
          {
            "id": "my-server",
            "name": "My Shadow Server",
            "channels": [
              {
                "id": "general",
                "title": "General",
                "description": "Main chat channel"
              },
              {
                "id": "ask-ai",
                "title": "Ask AI",
                "description": "Channel dedicated to AI assistant queries"
              }
            ]
          }
        ],
        "buddies": [
          {
            "id": "my-buddy",
            "name": "My AI Assistant",
            "description": "A helpful general-purpose AI assistant. Can answer questions, search the web, summarize content, and assist with everyday tasks."
          }
        ],
        "bindings": [
          {
            "targetId": "my-buddy",
            "targetType": "buddy",
            "servers": ["my-server"],
            "channels": ["general", "ask-ai"],
            "agentId": "my-agent",
            "replyPolicy": {
              "mode": "custom",
              "custom": {
                "replyToBuddy": false,
                "maxBuddyChainDepth": 2,
                "smartReply": true
              }
            }
          }
        ]
      }
    }
  ],
  "deployments": {
    "namespace": "shadowob-cloud",
    "agents": [
      {
        "id": "my-agent",
        "runtime": "openclaw",
        "configuration": {
          "openclaw": {
            "systemPrompt": "You are a helpful AI assistant named {{buddyName}}. Be concise, friendly, and accurate. When you don't know something, say so rather than guessing. You operate inside a Shadow chat server — users can @mention you or message you directly.",
            "tools": {
              "profile": "full",
              "web": {
                "search": {
                  "enabled": true
                },
                "fetch": {
                  "enabled": true
                }
              }
            }
          }
        },
        "use": [
          {
            "plugin": "model-provider",
            "options": {
              "tag": "flash"
            }
          }
        ]
      }
    ]
  },
  "i18n": {
    "en": {
      "name": "Shadow Cloud Basic",
      "description": "Basic single-agent template with a general AI assistant. Quick-start template for Shadow Cloud deployment."
    },
    "zh-CN": {
      "name": "Shadow Cloud 基础版",
      "description": "基础单智能体模板，包含一个通用 AI 助手。适用于 Shadow Cloud 快速部署。"
    }
  }
}

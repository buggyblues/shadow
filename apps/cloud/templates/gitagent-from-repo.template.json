// Template: Deploy agents defined in a gitagent-standard git repository.
// Supports two overlay strategies: init-container (default) and build-image.
// See https://github.com/open-gitagent/gitagent for the gitagent directory spec.
{
  "i18n": {
    "en": {
      "name": "${i18n:name}",
      "description": "${i18n:description}"
    },
    "zh-CN": {
      "name": "GitAgent 仓库部署",
      "description": "从 gitagent 标准 Git 仓库部署一个或多个智能体。支持通过 SSH 密钥或 HTTPS 令牌访问私有仓库。使用 Docker 镜像层或 Kubernetes init 容器将仓库文件叠加到智能体运行时。"
    }
  },
  "version": "1.0.0",
  "name": "GitAgent from Repository",
  "description": "Deploy one or more agents whose soul, rules, skills, tools, hooks, and scheduler are all defined in a gitagent-standard git repository. Supports private repos via SSH keys or HTTPS tokens. Uses Docker image layers (build-image) or Kubernetes init-containers (init-container) to overlay the repository files into the agent runtime.",
  "environment": "production",
  "team": {
    "name": "gitagent-team",
    "description": "Agents sourced from a gitagent-standard git repository"
  },
  "registry": {
    "providers": [
      {
        "id": "anthropic",
        "api": "anthropic",
        "apiKey": "${env:ANTHROPIC_API_KEY}",
        "models": [
          {
            "id": "claude-sonnet-4-5",
            "contextWindow": 200000
          },
          {
            "id": "claude-haiku-4-5",
            "contextWindow": 200000
          }
        ]
      },
      {
        "id": "openai",
        "api": "openai",
        "apiKey": "${env:OPENAI_API_KEY}",
        "models": [
          {
            "id": "gpt-4o",
            "contextWindow": 128000
          }
        ]
      }
    ]
  },
  "deployments": {
    "namespace": "gitagent-team",
    "imagePullPolicy": "IfNotPresent",
    "agents": [
      // Strategy 1: init-container (default) — no pre-build required.
      // Kubernetes adds an alpine/git init container that clones the repo at pod startup.
      // The cloned files are mounted at mountPath (/agent) for the OpenClaw runtime.
      {
        "id": "my-agent-init",
        "runtime": "openclaw",
        "description": "Agent whose definition lives in a git repository (init-container strategy)",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "git": {
                "url": "https://github.com/my-org/my-agents",
                "ref": "main",
                "dir": "agents/my-agent",
                "depth": 1
                // For private repos: use tokenSecret (HTTPS) or sshKeySecret (SSH)
              },
              "strategy": "init-container",
              "mountPath": "/agent"
              // Optional: restrict which files/dirs are copied. Default: all standard gitagent files.
              // "include": ["SOUL.md", "RULES.md", "skills", "tools"]
            }
          }
        ],
        // With gitagent source, SOUL.md → identity.personality, RULES.md → hard constraints.
        // You can still set identity here to override or supplement the git-sourced content.
        "identity": {
          "name": "My Agent"
        },
        "configuration": {
          "openclaw": {
            "tools": {
              "profile": "full",
              "web": {
                "fetch": {
                  "enabled": true
                }
              }
            }
          }
        },
        "resources": {
          "requests": {
            "cpu": "200m",
            "memory": "512Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        }
      },

      // Strategy 2: build-image — bakes git content into Docker image layers at build time.
      // Run `shadowob-cloud build` to generate and build the image before deploying.
      // Better for production: no git access needed at runtime, reproducible layers.
      {
        "id": "my-agent-built",
        "runtime": "openclaw",
        "description": "Agent whose definition is baked into a custom Docker image layer at build time",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "git": {
                "url": "https://github.com/my-org/my-agents",
                "ref": "v1.2.0",
                "dir": "agents/my-agent",
                "depth": 1,
                // tokenSecret can be a K8s Secret name or an env var like GITHUB_TOKEN for HTTPS private repos
                "tokenSecret": "${env:GITHUB_TOKEN}"
              },
              "strategy": "build-image",
              "mountPath": "/agent",
              "imageTag": "ghcr.io/my-org/my-agent:v1.2.0"
            }
          }
        ],
        // After `shadowob-cloud build`, set image to the built tag.
        "image": "ghcr.io/my-org/my-agent:v1.2.0",
        "identity": {
          "name": "My Agent (Built)"
        },
        "configuration": {
          "openclaw": {
            "tools": {
              "profile": "full"
            }
          }
        },
        "resources": {
          "requests": {
            "cpu": "200m",
            "memory": "512Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        }
      },

      // SSH-authenticated private repo — for repos that require SSH key access.
      // Create a K8s secret first: kubectl create secret generic git-ssh-key --from-file=ssh-privatekey=~/.ssh/id_ed25519
      {
        "id": "private-agent",
        "runtime": "openclaw",
        "description": "Agent from a private git repository authenticated via SSH",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "git": {
                "url": "git@github.com:my-org/private-agents.git",
                "ref": "main",
                "dir": "agents/private-agent",
                "sshKeySecret": "git-ssh-key"
              },
              "strategy": "init-container",
              "mountPath": "/agent"
            }
          }
        ],
        "identity": {
          "name": "Private Agent"
        },
        "configuration": {
          "openclaw": {
            "tools": {
              "profile": "full"
            }
          }
        },
        "resources": {
          "requests": {
            "cpu": "200m",
            "memory": "512Mi"
          },
          "limits": {
            "cpu": "1000m",
            "memory": "1Gi"
          }
        }
      },

      // Monorepo example — multiple agents from the same repository, different subdirectories.
      // All agents share the same git.url; each points to its own agents/<name> subdirectory.
      {
        "id": "monorepo-agent-a",
        "runtime": "openclaw",
        "description": "Agent A from a monorepo — agents/agent-a subdirectory",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "git": {
                "url": "https://github.com/my-org/agents-monorepo",
                "ref": "main",
                "dir": "agents/agent-a"
              },
              "strategy": "init-container",
              "mountPath": "/agent"
            }
          }
        ],
        "identity": {
          "name": "Agent A"
        },
        "configuration": {
          "openclaw": {
            "tools": {
              "profile": "full"
            }
          }
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "500m",
            "memory": "512Mi"
          }
        }
      },
      {
        "id": "monorepo-agent-b",
        "runtime": "openclaw",
        "description": "Agent B from the same monorepo — agents/agent-b subdirectory",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "git": {
                "url": "https://github.com/my-org/agents-monorepo",
                "ref": "main",
                "dir": "agents/agent-b"
              },
              "strategy": "init-container",
              "mountPath": "/agent"
            }
          }
        ],
        "identity": {
          "name": "Agent B"
        },
        "configuration": {
          "openclaw": {
            "tools": {
              "profile": "full"
            }
          }
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "500m",
            "memory": "512Mi"
          }
        }
      },

      // Local dev path example — reference a local gitagent directory during development.
      // At deploy time, shadowob-cloud reads the local files and enriches the agent config.
      // In production, switch source.git to a git URL.
      {
        "id": "local-dev-agent",
        "runtime": "openclaw",
        "description": "Agent loaded from a local gitagent directory (development only)",
        "use": [
          {
            "plugin": "gitagent",
            "options": {
              "path": "./my-agent",
              "strategy": "init-container",
              "mountPath": "/agent"
            }
          }
        ],
        "identity": {
          "name": "Local Dev Agent"
        },
        "configuration": {
          "openclaw": {
            "tools": {
              "profile": "full"
            }
          }
        },
        "resources": {
          "requests": {
            "cpu": "100m",
            "memory": "256Mi"
          },
          "limits": {
            "cpu": "500m",
            "memory": "512Mi"
          }
        }
      }
    ]
  }
}

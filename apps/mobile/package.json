{
  "name": "@shadowob/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "prestart": "pnpm --filter @shadowob/shared build",
    "start": "expo start",
    "preios": "pnpm --filter @shadowob/shared build",
    "android": "expo run:android",
    "preandroid": "pnpm --filter @shadowob/shared build",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "expo:check": "expo install --check",
    "bundle:ios": "expo export --platform ios --output-dir dist/ios --no-minify --clear",
    "bundle:android": "expo export --platform android --output-dir dist/android --no-minify --clear",
    "bundle": "pnpm run bundle:ios && pnpm run bundle:android",
    "check": "pnpm run lint && pnpm run style:check && pnpm run typecheck && pnpm run test && pnpm run expo:check",
    "verify:ios": "pnpm run check && pnpm run bundle:ios",
    "verify": "pnpm run check && pnpm run bundle",
    "smoke:ios": "node ../../scripts/mobile-ios-smoke.mjs",
    "lint": "biome check src/ app/",
    "style:check": "node ../../scripts/check-mobile-style.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@animatereactnative/marquee": "^0.5.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@shadowob/connector": "workspace:*",
    "@shadowob/oauth": "workspace:*",
    "@shadowob/sdk": "workspace:*",
    "@shadowob/shared": "workspace:*",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.100.14",
    "date-fns": "^4.1.0",
    "expo": "~54.0.36",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "^7.0.11",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "^19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-media-library": "^18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^25.8.14",
    "jszip": "^3.10.1",
    "lucide-react-native": "^0.577.0",
    "metro-runtime": "^0.83.3",
    "moti": "^0.30.0",
    "pinyin-pro": "^3.28.1",
    "react": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-agora": "^4.5.4",
    "react-native-enriched-markdown": "^0.4.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-quick-actions": "^0.3.13",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "~15.12.1",
    "react-native-webview": "^13.15.0",
    "react-native-worklets": "0.5.1",
    "rn-emoji-keyboard": "^1.7.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.13"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-quick-actions"
        ]
      }
    }
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}

# Voice Enhancement Service Configuration
# Copy this file to .env and fill in your API keys

# Provider: openai | anthropic | alibaba | custom
VOICE_ENHANCE_PROVIDER=openai

# API Key for the selected provider
VOICE_ENHANCE_API_KEY=your-api-key-here

# Optional: Custom base URL (for custom providers or proxies)
# VOICE_ENHANCE_BASE_URL=https://api.openai.com/v1

# Optional: Model selection (defaults to provider's default)
# VOICE_ENHANCE_MODEL=gpt-4o-mini

# Optional: Temperature (0-2, default: 0.3)
# VOICE_ENHANCE_TEMPERATURE=0.3

# Optional: Max tokens (default: 500)
# VOICE_ENHANCE_MAX_TOKENS=500

# Optional: Request timeout in ms (default: 5000)
# VOICE_ENHANCE_TIMEOUT=5000

# Optional: Enable/disable service (default: true)
# VOICE_ENHANCE_ENABLED=true

# Database
DATABASE_URL=postgresql://shadow:shadow@localhost:5432/shadow

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3001
HOST=0.0.0.0
# Local Server Space App command allowlist. Keep empty in production.
# SHADOWOB_SPACE_APP_ALLOW_PRIVATE_HOSTS=localhost,127.0.0.1,host.docker.internal,host.lima.internal

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=shadow

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Cloud SaaS Kubernetes target from shadowob-cloud cluster.json (optional)
# Run: shadowob-cloud cluster init --config cluster.json
# CLOUD_SAAS_CLUSTER_CONFIG_HOST_PATH=/absolute/host/path/to/cluster.json
# CLOUD_SAAS_CLUSTER_CONFIG=/app/cluster.json
# CLOUD_SAAS_CLUSTER_KUBECONFIG_HOST_PATH=/absolute/host/path/to/prod.yaml
# CLOUD_SAAS_CLUSTER_KUBECONFIG=/home/node/.shadow-cloud/clusters/prod.yaml
# Use standard Kubernetes Deployments for plain k3s clusters. Set agent-sandbox
# only on clusters that already have SandboxTemplate/SandboxClaim CRDs installed.
CLOUD_SAAS_WORKLOAD_BACKEND=deployment

# Cloud Computer runtime repair images.
CLOUD_COMPUTER_BROWSER_IMAGE=mcr.microsoft.com/playwright:v1.59.1-noble
CLOUD_COMPUTER_BROWSER_PROFILE_STORAGE_CLASS=standard
CLOUD_COMPUTER_DESKTOP_IMAGE=dorowu/ubuntu-desktop-lxde-vnc:latest

# Database Migration Strategy
# DB_PUSH=true  → dev mode: use drizzle-kit push (direct schema sync, no migration files)
# DB_PUSH=false → production mode: apply file-based migrations (default)
DB_PUSH=true

# Stripe (Recharge System)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OAuth — External Providers (Google, GitHub)
OAUTH_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloud Computer connector OAuth broker.
# Public origin registered in provider OAuth apps; callback is
# ${CLOUD_CONNECTOR_OAUTH_ORIGIN}/api/cloud-computers/oauth/callback.
CLOUD_CONNECTOR_OAUTH_ORIGIN=http://localhost:3001
# Initial OAuth-capable connector manifests use the naming convention:
# CLOUD_CONNECTOR_OAUTH_<PLUGIN_ID>_CLIENT_ID / _CLIENT_SECRET
# GitHub falls back to the platform GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET and
# reuses /api/auth/oauth/github/callback when connector-specific values are empty.
CLOUD_CONNECTOR_OAUTH_GITHUB_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_GITHUB_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_NOTION_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_NOTION_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_FIGMA_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_FIGMA_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_CANVA_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_CANVA_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_LINEAR_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_LINEAR_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_HUBSPOT_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_HUBSPOT_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_HUGGINGFACE_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_HUGGINGFACE_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_GOOGLE_WORKSPACE_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_GOOGLE_WORKSPACE_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_POSTHOG_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_POSTHOG_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_SENTRY_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_SENTRY_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_SUPABASE_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_SUPABASE_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_SALESFORCE_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_SALESFORCE_CLIENT_SECRET=
CLOUD_CONNECTOR_OAUTH_TENCENT_DOCS_CLIENT_ID=
CLOUD_CONNECTOR_OAUTH_TENCENT_DOCS_CLIENT_SECRET=

# Email login codes
# Configure either EMAIL_OTP_WEBHOOK_URL or SMTP_* for production.
EMAIL_OTP_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

{
  "name": "@shadowob/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "JWT_SECRET=${JWT_SECRET:-shadow-dev-jwt-secret-do-not-use-in-production} DB_PUSH=true tsx watch src/index.ts",
    "dev:backend": "JWT_SECRET=${JWT_SECRET:-shadow-dev-jwt-secret-do-not-use-in-production} DB_PUSH=true tsx watch src/index.ts",
    "dev:migrate": "JWT_SECRET=${JWT_SECRET:-shadow-dev-jwt-secret-do-not-use-in-production} tsx watch src/index.ts",
    "build": "pnpm --filter @shadowob/cloud build && tsup",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@hono/node-server": "^1.14.1",
    "@hono/zod-validator": "^0.7.6",
    "@shadowob/cloud": "workspace:*",
    "@shadowob/sdk": "workspace:*",
    "@shadowob/shared": "workspace:*",
    "@types/archiver": "^7.0.0",
    "agora-access-token": "^2.0.4",
    "archiver": "^7.0.1",
    "awilix": "^13.0.3",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.12.23",
    "ipaddr.js": "^2.4.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mime-types": "^3.0.1",
    "minio": "^8.0.5",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.9",
    "redis": "^5.0.1",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "stripe": "^21.0.1",
    "ws": "^8.19.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "@typia/unplugin": "^12.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "vitest": "^4.1.0"
  }
}

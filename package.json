{
  "name": "shadow",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "darwin",
        "linux"
      ],
      "cpu": [
        "current",
        "x64",
        "arm64"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "fs-xattr",
      "macos-alias",
      "node-pty",
      "sharp"
    ],
    "overrides": {
      "isbinaryfile": "^5.0.7",
      "axios": ">=1.15.0",
      "@xmldom/xmldom": ">=0.9.10",
      "basic-ftp": "5.3.1",
      "drizzle-orm": ">=0.45.2",
      "node-forge": ">=1.4.0",
      "socket.io-parser": ">=4.2.6",
      "shell-quote": "1.8.4",
      "fast-xml-parser": ">=5.5.9",
      "picomatch@<3": ">=2.3.2",
      "picomatch@>=3 <4": ">=3.0.2",
      "picomatch@>=4": ">=4.0.4",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "openclaw": "2026.6.10",
      "gh-pages": ">=5.0.0",
      "protobufjs": "8.6.4",
      "tar": ">=7.5.11",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.5",
      "tmp": ">=0.2.7",
      "form-data": ">=4.0.6",
      "hono": ">=4.12.25",
      "sigstore": ">=4.1.1",
      "ws": ">=8.21.0",
      "@expo/plist": "0.7.0",
      "@grpc/grpc-js": ">=1.14.4",
      "esbuild": ">=0.28.1",
      "undici@<6.27.0": "6.27.0",
      "undici@>=7 <8": "7.28.0",
      "undici@>=8 <9": "8.5.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "typia>typescript": ">=5.7.0"
      }
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2023-30533",
        "CVE-2024-22363",
        "CVE-2026-4926"
      ]
    },
    "patchedDependencies": {
      "@expo/plist@0.7.0": "patches/@expo__plist@0.7.0.patch",
      "appdmg@0.6.6": "patches/appdmg@0.6.6.patch",
      "ds-store@0.1.6": "patches/ds-store@0.1.6.patch"
    }
  },
  "scripts": {
    "dev": "pnpm dev:prepare && pnpm compose:db && pnpm compose:app:stop && pnpm dev:apps",
    "dev:apps": "node scripts/dev-apps.mjs",
    "dev:frontend": "node scripts/dev-frontend.mjs",
    "dev:prepare": "node scripts/ensure-node-pty-helper.mjs && node scripts/ensure-dev-builds.mjs",
    "compose:db": "docker compose up -d postgres redis minio",
    "compose:server": "node scripts/compose-server.mjs",
    "compose:dev": "pnpm compose:server",
    "compose:app:stop": "docker compose stop server web admin",
    "compose:db:stop": "docker compose stop postgres redis minio",
    "compose:down": "docker compose down",
    "mobile:check": "pnpm -C apps/mobile check",
    "mobile:style:check": "pnpm -C apps/mobile style:check",
    "mobile:bundle": "pnpm -C apps/mobile bundle",
    "mobile:verify:ios": "pnpm -C apps/mobile verify:ios",
    "mobile:verify": "pnpm -C apps/mobile verify",
    "mobile:smoke:ios": "pnpm -C apps/mobile smoke:ios",
    "build:packages": "pnpm --filter @shadowob/shared build && pnpm --filter @shadowob/sdk build && pnpm --parallel --filter @shadowob/oauth --filter @shadowob/openclaw-shadowob --filter @shadowob/cli --filter @shadowob/connector build && pnpm --filter @shadowob/cloud build:cli",
    "build": "pnpm build:packages && pnpm -r build",
    "lint": "biome lint . --diagnostic-level=error",
    "lint:fix": "biome check --write . --diagnostic-level=error",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --parallel --if-present typecheck",
    "typecheck:staged": "node scripts/typecheck-staged.mjs",
    "check:migrations": "node scripts/check-drizzle-migrations.mjs",
    "check:sdk-versions": "node scripts/check-sdk-version-consistency.mjs",
    "check:workspace-deps": "node scripts/check-workspace-deps.mjs",
    "check:exports": "node scripts/check-exports-consistency.mjs",
    "check:audit": "node scripts/check-npm-audit.mjs",
    "check:dashboard-style": "node scripts/check-dashboard-style.mjs",
    "check:mobile-style": "node scripts/check-mobile-style.mjs",
    "check:dashboard-i18n": "node scripts/check-dashboard-i18n.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:security-pr": "node scripts/check-security-pr.mjs",
    "check:pre-push": "pnpm check:migrations && node scripts/pre-push-checks.mjs && pnpm check:security-pr && pnpm check:dashboard-style && pnpm check:dashboard-i18n && pnpm check:mobile-style",
    "check:all": "pnpm check:migrations && pnpm check:sdk-versions && pnpm check:workspace-deps && pnpm check:exports && pnpm check:i18n && pnpm check:security-pr && pnpm check:dashboard-style && pnpm check:dashboard-i18n && pnpm check:mobile-style && pnpm check:pre-push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e:cloud:cli": "pnpm --filter @shadowob/cloud test:e2e:cli",
    "e2e:cloud:dashboard": "pnpm --filter @shadowob/cloud test:e2e:dashboard",
    "e2e:screenshots:seed": "node scripts/e2e/seed-screenshot-env.mjs",
    "e2e:screenshots:web": "E2E_SCREENSHOT_DEVICE_SCALE_FACTOR=2 pnpm --filter @shadowob/desktop exec playwright test -c playwright.web.config.ts",
    "e2e:screenshots:local": "pnpm e2e:screenshots:seed && pnpm e2e:screenshots:web",
    "e2e:screenshots:all": "pnpm e2e:screenshots:local",
    "e2e:docs-screenshots:seed": "node scripts/e2e/seed-docs-screenshot-env.mjs",
    "e2e:docs-screenshots:web": "E2E_SESSION_PATH=.tmp/e2e/docs-screenshot-session.json E2E_SCREENSHOT_DIR=docs/e2e/screenshots E2E_SCREENSHOT_DEVICE_SCALE_FACTOR=2 pnpm --filter @shadowob/desktop exec playwright test -c playwright.web.config.ts 04_docs_screenshots.spec.ts",
    "e2e:docs-screenshots:local": "pnpm e2e:docs-screenshots:seed && pnpm e2e:docs-screenshots:web",
    "compose:e2e:screenshots": "docker compose -f docker-compose.e2e.yml up --build --abort-on-container-exit --exit-code-from e2e-runner e2e-runner",
    "smoke:openclaw-shadowob": "node scripts/smoke/openclaw-shadowob-smoke.mjs",
    "smoke:openclaw-shadowob:basic": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite basic",
    "smoke:openclaw-shadowob:advanced": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite advanced",
    "smoke:openclaw-shadowob:dm": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite dm",
    "smoke:openclaw-shadowob:rules": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite rules",
    "smoke:openclaw-shadowob:multi": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite multi",
    "smoke:openclaw-shadowob:cron": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite cron",
    "smoke:openclaw-shadowob:thread": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite thread --isolated",
    "smoke:openclaw-shadowob:dm-advanced": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite dm-advanced --isolated",
    "smoke:openclaw-shadowob:media-outbound": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite media-outbound --isolated",
    "smoke:openclaw-shadowob:interactive": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite interactive --isolated",
    "smoke:openclaw-shadowob:discussion": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite discussion --isolated",
    "smoke:openclaw-shadowob:parallel": "node scripts/smoke/openclaw-shadowob-smoke-parallel.mjs",
    "smoke:openclaw-shadowob:all": "node scripts/smoke/openclaw-shadowob-smoke.mjs --suite all",
    "db:generate": "pnpm --filter @shadowob/server db:generate",
    "db:migration:new": "node scripts/create-drizzle-migration.mjs",
    "db:migrate": "pnpm --filter @shadowob/server db:migrate",
    "db:studio": "pnpm --filter @shadowob/server db:studio",
    "publish:packages": "node scripts/publish-packages.mjs",
    "prepare": "husky && node scripts/fix-flash-symlinks.mjs && node scripts/ensure-node-pty-helper.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx}": [
      "bash -c 'pnpm typecheck:staged'"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}

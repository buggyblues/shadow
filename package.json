{
  "name": "shadow",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "fs-xattr",
      "macos-alias",
      "sharp"
    ],
    "overrides": {
      "isbinaryfile": "^5.0.7"
    }
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check:migrations": "node scripts/check-drizzle-migrations.mjs",
    "check:sdk-versions": "node scripts/check-sdk-version-consistency.mjs",
    "check:workspace-deps": "node scripts/check-workspace-deps.mjs",
    "check:exports": "node scripts/check-exports-consistency.mjs",
    "check:pre-push": "node scripts/pre-push-checks.mjs",
    "check:all": "pnpm check:sdk-versions && pnpm check:workspace-deps && pnpm check:exports && pnpm check:pre-push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e:screenshots:readme": "node scripts/e2e/capture-readme-gallery.mjs",
    "e2e:screenshots:seed": "node scripts/e2e/seed-screenshot-env.mjs",
    "e2e:screenshots:web": "pnpm --filter @shadowob/desktop exec playwright test -c playwright.web.config.ts",
    "e2e:screenshots:local": "pnpm e2e:screenshots:seed && pnpm e2e:screenshots:web",
    "e2e:screenshots:all": "pnpm e2e:screenshots:readme && pnpm e2e:screenshots:local",
    "e2e:screenshots:docker": "docker compose -f docker-compose.e2e.yml up --build --abort-on-container-exit --exit-code-from e2e-runner e2e-runner",
    "e2e:showcase": "node scripts/e2e/generate-showcase.mjs",
    "e2e:demo-flow": "pnpm --filter @shadowob/desktop exec playwright test -c playwright.demo.config.ts",
    "e2e:demo-gif": "node scripts/e2e/demo-gif/orchestrate.mjs",
    "db:generate": "pnpm --filter @shadowob/server db:generate",
    "db:migrate": "pnpm --filter @shadowob/server db:migrate",
    "db:studio": "pnpm --filter @shadowob/server db:studio",
    "publish:packages": "node scripts/publish-packages.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}

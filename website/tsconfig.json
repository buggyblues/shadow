{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx"
  },
  "include": [
    "env.d.ts",
    "rspress.config.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "theme/**/*.ts",
    "theme/**/*.tsx"
  ]
}

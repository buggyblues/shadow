{
  "name": "@shadowob/qna-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "compose:dev": "sh -c 'test -f ../.env || cp ../.env.example ../.env; QNA_DEV_APP_DIR=$(pwd) docker compose -f ../docker-compose.yaml -f docker-compose.dev.yaml --env-file ../.env up qna --build'",
    "compose:dev:down": "sh -c 'test -f ../.env || cp ../.env.example ../.env; QNA_DEV_APP_DIR=$(pwd) docker compose -f ../docker-compose.yaml -f docker-compose.dev.yaml --env-file ../.env down'",
    "dev": "tsx watch src/server.ts",
    "dev:hot": "sh -c 'vite --host 0.0.0.0 --port ${QNA_VITE_PORT:-5170} & tsx watch src/server.ts'",
    "dev:hot:install": "sh -c 'pnpm install --filter @shadowob/qna-app... --prod=false --frozen-lockfile --ignore-scripts --package-import-method=copy && pnpm dev:hot'",
    "start": "tsx src/server.ts",
    "test": "QNA_DATA_FILE=.tmp/qna-test.json vitest run",
    "typegen": "shadow-server-app typegen shadow-app.local.json src/shadow-app.generated.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@shadowob/sdk": "workspace:*",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.168.2",
    "dompurify": "^3.4.11",
    "dotenv": "^17.3.1",
    "hono": "^4.12.27",
    "lucide-react": "^0.513.0",
    "marked": "^17.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  }
}

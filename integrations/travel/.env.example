PORT=4224
TRAVEL_DATA_DIR=./data
TRAVEL_PUBLIC_BASE_URL=http://localhost:4224
SHADOWOB_API_BASE_URL=http://localhost:3002
TRAVEL_ALLOW_LOCAL_ACTOR=true
TRAVEL_REQUIRE_OAUTH=false
TRAVEL_OAUTH_CLIENT_ID=
TRAVEL_OAUTH_CLIENT_SECRET=
TRAVEL_OAUTH_SCOPE=user:read servers:read channels:read messages:write
TRAVEL_OAUTH_REDIRECT_URI=http://localhost:4224/shadow/oauth/callback
TRAVEL_OAUTH_COOKIE_SECRET=change-me-in-production
TRAVEL_ENCRYPTION_KEY=change-me-in-production
# Optional server-side installation/PAT credential used only to list human community members.
TRAVEL_SHADOW_INSTALLATION_TOKEN=
# Mark Buddy planning tasks failed when no required Travel plan draft arrives in time.
TRAVEL_BUDDY_TASK_TIMEOUT_MS=900000

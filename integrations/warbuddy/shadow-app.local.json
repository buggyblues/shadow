{
  "schemaVersion": "shadow.app/1",
  "appKey": "warbuddy",
  "name": "WarBuddy Arena",
  "description": "A squad-based pixel tank arena with ranked battles, live rooms, Buddy coaching, and frame-by-frame replay review.",
  "version": "1.0.0",
  "iconUrl": "http://localhost:4218/assets/icon.svg",
  "marketplace": {
    "tagline": "A pixel tank arena with ranked battles, live rooms, and Buddy coaching.",
    "summary": "WarBuddy Arena gives a server a squad-based pixel tank battleground with rosters, strategy versions, ranked matches, realtime battle rooms, replay inspection, and Buddy coaching. It is built for competitive play where tactics and review matter.",
    "categories": ["Games", "Social", "Strategy"],
    "supportedLanguages": ["English", "中文"],
    "coverImageUrl": "http://localhost:4218/assets/cover.png",
    "gallery": [
      {
        "url": "http://localhost:4218/assets/cover.png",
        "type": "image",
        "alt": "WarBuddy cover"
      }
    ],
    "links": [
      {
        "label": "Home",
        "url": "http://localhost:4218/shadow/server",
        "type": "website"
      }
    ],
    "publisher": {
      "name": "Shadow"
    }
  },
  "iframe": {
    "entry": "http://localhost:4218/shadow/server",
    "allowedOrigins": ["http://localhost:4218"]
  },
  "api": {
    "baseUrl": "http://localhost:4218",
    "auth": {
      "type": "oauth2-bearer"
    }
  },
  "access": {
    "defaultPermissions": [
      "warbuddy.tanks:read",
      "warbuddy.tanks:write",
      "warbuddy.matches:read",
      "warbuddy.matches:write",
      "warbuddy.leaderboard:read",
      "warbuddy.teams:read",
      "warbuddy.teams:write",
      "warbuddy.rooms:read",
      "warbuddy.rooms:write",
      "warbuddy.replays:write",
      "warbuddy.buddies:write"
    ],
    "defaultApprovalMode": "none"
  },
  "commands": [
    {
      "name": "teams.list",
      "title": "List squads",
      "description": "Read WarBuddy squads for the current arena, including the calling actor's squad.",
      "ingress": {
        "path": "/.shadow/commands/teams.list",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.teams:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "teams.create",
      "title": "Create squad",
      "description": "Create or update the calling actor's WarBuddy squad. Squads are required before Buddy strategy delegation or live rooms.",
      "ingress": {
        "path": "/.shadow/commands/teams.create",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.teams:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "description": {
            "type": "string",
            "maxLength": 400
          },
          "color": {
            "type": "string",
            "maxLength": 7
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "rooms.list",
      "title": "List live rooms",
      "description": "Read recent WarBuddy live rooms and room codes.",
      "ingress": {
        "path": "/.shadow/commands/rooms.list",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.rooms:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "rooms.create",
      "title": "Create live room",
      "description": "Create a WebSocket-backed WarBuddy live room for auto, manual, or co-op play.",
      "ingress": {
        "path": "/.shadow/commands/rooms.create",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.rooms:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 80
          },
          "mapId": {
            "type": "string",
            "maxLength": 80
          },
          "teamId": {
            "type": "string",
            "maxLength": 80
          },
          "mode": {
            "enum": ["auto", "manual", "coop"]
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "rooms.join",
      "title": "Join live room",
      "description": "Join an existing WarBuddy live room by room code.",
      "ingress": {
        "path": "/.shadow/commands/rooms.join",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.rooms:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 4,
            "maxLength": 12
          },
          "teamId": {
            "type": "string",
            "maxLength": 80
          },
          "mode": {
            "enum": ["auto", "manual", "coop"]
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "tanks.list",
      "title": "List tanks",
      "description": "Read the server arena tank roster, including Buddy-owned tanks, skills, versions, ratings, and public notes.",
      "ingress": {
        "path": "/.shadow/commands/tanks.list",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.tanks:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "maxLength": 120
          },
          "ownerKind": {
            "enum": ["all", "buddy", "user", "local", "demo"]
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "tanks.get",
      "title": "Get tank",
      "description": "Read one tank profile, latest Buddy strategy version, notes, and battle summary.",
      "ingress": {
        "path": "/.shadow/commands/tanks.get",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.tanks:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tankId": {
            "type": "string",
            "maxLength": 80
          },
          "mine": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "tanks.saveCode",
      "title": "Submit Buddy strategy",
      "description": "Buddy-facing command for creating or updating a squad tank strategy version and skill selection.",
      "ingress": {
        "path": "/.shadow/commands/tanks.saveCode",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.tanks:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "tankId": {
            "type": "string",
            "maxLength": 80
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "appearance": {
            "type": "string",
            "maxLength": 240
          },
          "skillType": {
            "enum": ["shield", "freeze", "stun", "overload", "cloak", "poison", "teleport", "boost"]
          },
          "code": {
            "type": "string",
            "maxLength": 12000
          },
          "notes": {
            "type": "string",
            "maxLength": 1000
          },
          "submittedBy": {
            "type": "string",
            "maxLength": 80
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.simulate",
      "title": "Simulate battle",
      "description": "Run a private candidate battle without changing standings. The response includes replay frames, events, and tactical summary.",
      "ingress": {
        "path": "/.shadow/commands/matches.simulate",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.matches:write",
      "action": "generate",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "challengerTankId": {
            "type": "string",
            "maxLength": 80
          },
          "defenderTankId": {
            "type": "string",
            "maxLength": 80
          },
          "candidateCode": {
            "type": "string",
            "maxLength": 12000
          },
          "candidateName": {
            "type": "string",
            "maxLength": 80
          },
          "candidateSkillType": {
            "enum": ["shield", "freeze", "stun", "overload", "cloak", "poison", "teleport", "boost"]
          },
          "opponentId": {
            "type": "string",
            "maxLength": 80
          },
          "mapId": {
            "type": "string",
            "maxLength": 80
          },
          "seed": {
            "type": "integer"
          },
          "fps": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60
          },
          "durationSeconds": {
            "type": "number",
            "minimum": 4,
            "maximum": 120
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.challenge",
      "title": "Launch recorded battle",
      "description": "Create a recorded Buddy-versus-Buddy tank battle, update wins/losses/rating, and store the replay.",
      "ingress": {
        "path": "/.shadow/commands/matches.challenge",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.matches:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["challengerTankId", "defenderTankId"],
        "properties": {
          "challengerTankId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "defenderTankId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "mapId": {
            "type": "string",
            "maxLength": 80
          },
          "seed": {
            "type": "integer"
          },
          "fps": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60
          },
          "durationSeconds": {
            "type": "number",
            "minimum": 4,
            "maximum": 120
          },
          "announceChannelName": {
            "type": "string",
            "maxLength": 80
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.list",
      "title": "List recorded battles",
      "description": "Read recent recorded tank battles with winner, map, reason, excitement score, and replay id.",
      "ingress": {
        "path": "/.shadow/commands/matches.list",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.matches:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tankId": {
            "type": "string",
            "maxLength": 80
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.get",
      "title": "Get replay",
      "description": "Read one recorded match as replay summary, event stream, raw frame data, or a bounded frame slice.",
      "ingress": {
        "path": "/.shadow/commands/matches.get",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.matches:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId"],
        "properties": {
          "matchId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "view": {
            "enum": ["summary", "events", "raw", "frames"]
          },
          "from": {
            "type": "integer",
            "minimum": 0,
            "maximum": 500
          },
          "to": {
            "type": "integer",
            "minimum": 0,
            "maximum": 500
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.markRead",
      "title": "Mark replay read",
      "description": "Mark a recorded battle replay as viewed for the calling actor.",
      "ingress": {
        "path": "/.shadow/commands/matches.markRead",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.matches:read",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId"],
        "properties": {
          "matchId": {
            "type": "string",
            "maxLength": 80,
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "replay.comment",
      "title": "Comment on replay frame",
      "description": "Add a frame-level replay comment with an optional normalized rectangle selection.",
      "ingress": {
        "path": "/.shadow/commands/replay.comment",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.replays:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId", "frame", "body"],
        "properties": {
          "matchId": {
            "type": "string",
            "maxLength": 80,
            "minLength": 1
          },
          "frame": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600
          },
          "rect": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "y": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "width": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "height": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "replay.reviewBrief",
      "title": "Summarize replay comments",
      "description": "Summarize all replay comments so the result can be sent to a Buddy as a strategy adjustment task.",
      "ingress": {
        "path": "/.shadow/commands/replay.reviewBrief",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.matches:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId"],
        "properties": {
          "matchId": {
            "type": "string",
            "maxLength": 80,
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "leaderboard.get",
      "title": "Read leaderboard",
      "description": "Read tank standings sorted by rating, wins, win rate, or excitement.",
      "ingress": {
        "path": "/.shadow/commands/leaderboard.get",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.leaderboard:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sort": {
            "enum": ["rating", "wins", "win_rate", "excitement"]
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "battle.brief",
      "title": "Brief Buddies for battle",
      "description": "Send Inbox task cards to selected server Buddies with the WarBuddy rules, command names, and suggested workflow.",
      "ingress": {
        "path": "/.shadow/commands/battle.brief",
        "auth": "shadow-command-jwt"
      },
      "permission": "warbuddy.buddies:write",
      "action": "write",
      "dataClass": "channel-private",
      "inputSchema": {
        "type": "object",
        "required": ["targets"],
        "properties": {
          "targets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "object",
              "properties": {
                "agentId": {
                  "type": "string",
                  "maxLength": 80
                },
                "assigneeLabel": {
                  "type": "string",
                  "maxLength": 80
                }
              },
              "additionalProperties": false
            }
          },
          "mapId": {
            "type": "string",
            "maxLength": 80
          },
          "teamId": {
            "type": "string",
            "maxLength": 80
          },
          "opponentHint": {
            "type": "string",
            "maxLength": 160
          },
          "notes": {
            "type": "string",
            "maxLength": 1200
          }
        },
        "additionalProperties": false
      }
    }
  ],
  "skills": [
    {
      "name": "warbuddy-playbook",
      "description": "Coach a WarBuddy squad: inspect replays, submit strategy versions, simulate opponents, and challenge server Buddies.",
      "commandHints": [
        "warbuddy teams.list",
        "warbuddy battle.brief",
        "warbuddy tanks.get",
        "warbuddy tanks.saveCode",
        "warbuddy matches.simulate",
        "warbuddy matches.challenge",
        "warbuddy matches.get"
      ]
    }
  ],
  "events": ["warbuddy.match.recorded"],
  "help": {
    "overview": "WarBuddy Arena is a squad-based combined-arms tank battle integration. A human or Buddy can field a tank and engineer squad, run deterministic matches, join live rooms, and review frame-by-frame replays.",
    "usage": "Players create squads in the App, then delegate improvement work with battle.brief. Buddies inspect tanks and replays, submit strategy versions with tanks.saveCode, simulate privately, and challenge when ready.",
    "details": "Buddy runtime contract: prefer separate handlers onTankIdle(tank, enemy, game, squad) and onEngineerIdle(engineer, enemy, game, squad). Use tank.moveTo(x,y) or engineer.moveTo(x,y) for built-in pathing, step(direction) for cardinal steps, moveVector(x,y) for one-step vectors, tank.face(direction|angle), tank.faceAngle(angle), tank.fire(), tank.speak(text), engineer.speak(text), engineer.bomb(), print(...args), plus the tank skill method on tank that matches squad.skill.type. Legacy onIdle, drive, aim, and engineer.move still work. Positions are arrays [x, y]. Map values are \"x\" wall, \"m\" destructible dirt mound, \"o\" grass, \"w\" water, and \".\" open ground. Grass and cloak can hide enemy units; enemy bullets are visible only through line of sight."
  },
  "realtime": {
    "transports": ["sse"],
    "subscribe": {
      "events": ["warbuddy.match.recorded"]
    },
    "stateSync": {
      "model": "frame-sync",
      "authority": "server",
      "tickRate": 6
    }
  },
  "i18n": {
    "zh-CN": {
      "name": "WarBuddy 竞技场",
      "description": "小队制像素坦克竞技场，支持排位战、实时房间、Buddy 教练和逐帧回放复盘。",
      "marketplace": {
        "tagline": "带排位战、实时房间和 Buddy 教练的像素坦克竞技场。",
        "summary": "WarBuddy 竞技场为服务器提供小队制像素坦克战场，包括阵容、策略版本、排位赛、实时战斗房间、回放检查和 Buddy 教练。它适合重视战术和复盘的竞技玩法。",
        "categories": ["游戏", "社交", "策略"],
        "gallery": [
          {
            "alt": "WarBuddy 封面"
          }
        ],
        "links": [
          {
            "label": "主页"
          }
        ]
      }
    }
  }
}

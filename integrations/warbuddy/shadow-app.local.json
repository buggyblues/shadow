{
  "schemaVersion": "shadow.app/1",
  "appKey": "shadow-warbuddy",
  "name": "WarBuddy Arena",
  "description": "A squad-based pixel tank arena with ranked battles, live rooms, Buddy coaching, and frame-by-frame replay review.",
  "version": "1.0.0",
  "iconUrl": "http://localhost:4218/assets/icon.svg",
  "iframe": {
    "entry": "http://localhost:4218/shadow/server",
    "allowedOrigins": ["http://localhost:4218"]
  },
  "api": {
    "baseUrl": "http://localhost:4218",
    "auth": {
      "type": "oauth2-bearer"
    }
  },
  "access": {
    "defaultPermissions": [
      "warbuddy.tanks:read",
      "warbuddy.tanks:write",
      "warbuddy.matches:read",
      "warbuddy.matches:write",
      "warbuddy.leaderboard:read",
      "warbuddy.teams:read",
      "warbuddy.teams:write",
      "warbuddy.rooms:read",
      "warbuddy.rooms:write",
      "warbuddy.replays:write",
      "warbuddy.buddies:write"
    ],
    "defaultApprovalMode": "none"
  },
  "commands": [
    {
      "name": "teams.list",
      "title": "List squads",
      "description": "Read WarBuddy squads for the current arena, including the calling actor's squad.",
      "path": "/api/shadow/commands/teams.list",
      "permission": "warbuddy.teams:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "teams.create",
      "title": "Create squad",
      "description": "Create or update the calling actor's WarBuddy squad. Squads are required before Buddy strategy delegation or live rooms.",
      "path": "/api/shadow/commands/teams.create",
      "permission": "warbuddy.teams:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 60 },
          "description": { "type": "string", "maxLength": 400 },
          "color": { "type": "string", "maxLength": 7 }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "rooms.list",
      "title": "List live rooms",
      "description": "Read recent WarBuddy live rooms and room codes.",
      "path": "/api/shadow/commands/rooms.list",
      "permission": "warbuddy.rooms:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "rooms.create",
      "title": "Create live room",
      "description": "Create a WebSocket-backed WarBuddy live room for auto, manual, or co-op play.",
      "path": "/api/shadow/commands/rooms.create",
      "permission": "warbuddy.rooms:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 80 },
          "mapId": { "type": "string", "maxLength": 80 },
          "teamId": { "type": "string", "maxLength": 80 },
          "mode": { "enum": ["auto", "manual", "coop"] }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "rooms.join",
      "title": "Join live room",
      "description": "Join an existing WarBuddy live room by room code.",
      "path": "/api/shadow/commands/rooms.join",
      "permission": "warbuddy.rooms:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "type": "string", "minLength": 4, "maxLength": 12 },
          "teamId": { "type": "string", "maxLength": 80 },
          "mode": { "enum": ["auto", "manual", "coop"] }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "tanks.list",
      "title": "List tanks",
      "description": "Read the server arena tank roster, including Buddy-owned tanks, skills, versions, ratings, and public notes.",
      "path": "/api/shadow/commands/tanks.list",
      "permission": "warbuddy.tanks:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "maxLength": 120
          },
          "ownerKind": {
            "enum": ["all", "buddy", "user", "local", "demo"]
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "tanks.get",
      "title": "Get tank",
      "description": "Read one tank profile, latest Buddy strategy version, notes, and battle summary.",
      "path": "/api/shadow/commands/tanks.get",
      "permission": "warbuddy.tanks:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tankId": {
            "type": "string",
            "maxLength": 80
          },
          "mine": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "tanks.saveCode",
      "title": "Submit Buddy strategy",
      "description": "Buddy-facing command for creating or updating a squad tank strategy version and skill selection.",
      "path": "/api/shadow/commands/tanks.saveCode",
      "permission": "warbuddy.tanks:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "tankId": {
            "type": "string",
            "maxLength": 80
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "appearance": {
            "type": "string",
            "maxLength": 240
          },
          "skillType": {
            "enum": ["shield", "freeze", "stun", "overload", "cloak", "poison", "teleport", "boost"]
          },
          "code": {
            "type": "string",
            "minLength": 1,
            "maxLength": 12000
          },
          "notes": {
            "type": "string",
            "maxLength": 1000
          },
          "submittedBy": {
            "type": "string",
            "maxLength": 80
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.simulate",
      "title": "Simulate battle",
      "description": "Run a private candidate battle without changing standings. The response includes replay frames, events, and tactical summary.",
      "path": "/api/shadow/commands/matches.simulate",
      "permission": "warbuddy.matches:write",
      "action": "generate",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "challengerTankId": {
            "type": "string",
            "maxLength": 80
          },
          "defenderTankId": {
            "type": "string",
            "maxLength": 80
          },
          "candidateCode": {
            "type": "string",
            "maxLength": 12000
          },
          "candidateName": {
            "type": "string",
            "maxLength": 80
          },
          "candidateSkillType": {
            "enum": ["shield", "freeze", "stun", "overload", "cloak", "poison", "teleport", "boost"]
          },
          "opponentId": {
            "type": "string",
            "maxLength": 80
          },
          "mapId": {
            "type": "string",
            "maxLength": 80
          },
          "seed": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.challenge",
      "title": "Launch recorded battle",
      "description": "Create a recorded Buddy-versus-Buddy tank battle, update wins/losses/rating, and store the replay.",
      "path": "/api/shadow/commands/matches.challenge",
      "permission": "warbuddy.matches:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["challengerTankId", "defenderTankId"],
        "properties": {
          "challengerTankId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "defenderTankId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "mapId": {
            "type": "string",
            "maxLength": 80
          },
          "seed": {
            "type": "integer"
          },
          "announceChannelName": {
            "type": "string",
            "maxLength": 80
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.list",
      "title": "List recorded battles",
      "description": "Read recent recorded tank battles with winner, map, reason, excitement score, and replay id.",
      "path": "/api/shadow/commands/matches.list",
      "permission": "warbuddy.matches:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tankId": {
            "type": "string",
            "maxLength": 80
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.get",
      "title": "Get replay",
      "description": "Read one recorded match as replay summary, event stream, raw frame data, or a bounded frame slice.",
      "path": "/api/shadow/commands/matches.get",
      "permission": "warbuddy.matches:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId"],
        "properties": {
          "matchId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "view": {
            "enum": ["summary", "events", "raw", "frames"]
          },
          "from": {
            "type": "integer",
            "minimum": 0,
            "maximum": 500
          },
          "to": {
            "type": "integer",
            "minimum": 0,
            "maximum": 500
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "matches.markRead",
      "title": "Mark replay read",
      "description": "Mark a recorded battle replay as viewed for the calling actor.",
      "path": "/api/shadow/commands/matches.markRead",
      "permission": "warbuddy.matches:read",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId"],
        "properties": {
          "matchId": {
            "type": "string",
            "maxLength": 80,
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "replay.comment",
      "title": "Comment on replay frame",
      "description": "Add a frame-level replay comment with an optional normalized rectangle selection.",
      "path": "/api/shadow/commands/replay.comment",
      "permission": "warbuddy.replays:write",
      "action": "write",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId", "frame", "body"],
        "properties": {
          "matchId": { "type": "string", "maxLength": 80, "minLength": 1 },
          "frame": { "type": "integer", "minimum": 0, "maximum": 10000 },
          "body": { "type": "string", "minLength": 1, "maxLength": 600 },
          "rect": {
            "type": "object",
            "properties": {
              "x": { "type": "number", "minimum": 0, "maximum": 1 },
              "y": { "type": "number", "minimum": 0, "maximum": 1 },
              "width": { "type": "number", "minimum": 0, "maximum": 1 },
              "height": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "replay.reviewBrief",
      "title": "Summarize replay comments",
      "description": "Summarize all replay comments so the result can be sent to a Buddy as a strategy adjustment task.",
      "path": "/api/shadow/commands/replay.reviewBrief",
      "permission": "warbuddy.matches:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["matchId"],
        "properties": {
          "matchId": { "type": "string", "maxLength": 80, "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "leaderboard.get",
      "title": "Read leaderboard",
      "description": "Read tank standings sorted by rating, wins, win rate, or excitement.",
      "path": "/api/shadow/commands/leaderboard.get",
      "permission": "warbuddy.leaderboard:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sort": {
            "enum": ["rating", "wins", "win_rate", "excitement"]
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "battle.brief",
      "title": "Brief Buddies for battle",
      "description": "Send Inbox task cards to selected server Buddies with the WarBuddy rules, command names, and suggested workflow.",
      "path": "/api/shadow/commands/battle.brief",
      "permission": "warbuddy.buddies:write",
      "action": "write",
      "dataClass": "channel-private",
      "inputSchema": {
        "type": "object",
        "required": ["targets"],
        "properties": {
          "targets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "object",
              "properties": {
                "agentId": {
                  "type": "string",
                  "maxLength": 80
                },
                "assigneeLabel": {
                  "type": "string",
                  "maxLength": 80
                }
              },
              "additionalProperties": false
            }
          },
          "mapId": {
            "type": "string",
            "maxLength": 80
          },
          "teamId": {
            "type": "string",
            "maxLength": 80
          },
          "opponentHint": {
            "type": "string",
            "maxLength": 160
          },
          "notes": {
            "type": "string",
            "maxLength": 1200
          }
        },
        "additionalProperties": false
      }
    }
  ],
  "skills": [
    {
      "name": "shadow-warbuddy-playbook",
      "description": "Coach a WarBuddy squad: inspect replays, submit strategy versions, simulate opponents, and challenge server Buddies.",
      "commandHints": [
        "shadow-warbuddy teams.list",
        "shadow-warbuddy battle.brief",
        "shadow-warbuddy tanks.get",
        "shadow-warbuddy tanks.saveCode",
        "shadow-warbuddy matches.simulate",
        "shadow-warbuddy matches.challenge",
        "shadow-warbuddy matches.get"
      ]
    }
  ],
  "events": ["warbuddy.match.recorded"],
  "help": {
    "overview": "WarBuddy Arena is a squad-based combined-arms tank battle integration. A human or Buddy can field a tank and engineer squad, run deterministic matches, join live rooms, and review frame-by-frame replays.",
    "usage": "Players create squads in the Server App, then delegate improvement work with battle.brief. Buddies inspect tanks and replays, submit strategy versions with tanks.saveCode, simulate privately, and challenge when ready.",
    "details": "Buddy runtime contract: define function onIdle(me, enemy, game). Use me.tank.drive(x,y), me.tank.drive(direction), me.tank.aim(angle), me.tank.aim(direction), me.tank.fire(), me.engineer.move(x,y), me.engineer.move(direction), me.engineer.bomb(), me.speak(\"text\"), speak(\"text\"), print(...args), plus the tank skill method on me.tank that matches me.skill.type. Positions are arrays [x, y]. Map values are \"x\" wall, \"m\" destructible dirt mound, \"o\" grass, \"w\" water, and \".\" open ground. Grass and cloak can hide enemy units; enemy bullets are visible only through line of sight."
  },
  "realtime": {
    "transports": ["sse"],
    "subscribe": {
      "events": ["warbuddy.match.recorded"]
    },
    "stateSync": {
      "model": "frame-sync",
      "authority": "server",
      "tickRate": 6
    }
  }
}

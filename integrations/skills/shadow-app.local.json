{
  "schemaVersion": "shadow.app/1",
  "appKey": "shadow-skills",
  "name": "Shadow Skills",
  "description": "A server-owned skill library where people and Buddies can publish, discover, export, and install reusable working skills.",
  "version": "1.0.0",
  "iconUrl": "http://localhost:4220/assets/icon.svg",
  "marketplace": {
    "tagline": "A server-owned library for reusable working skills.",
    "summary": "Shadow Skills lets a server publish, discover, export, install, and refresh reusable skills. People and Buddies can keep operational know-how in a shared library instead of burying prompts, runbooks, and workflows across channels.",
    "categories": ["开发工具", "效率", "知识"],
    "supportedLanguages": ["English", "中文"],
    "coverImageUrl": "http://localhost:4220/assets/cover.png",
    "gallery": [
      {
        "url": "http://localhost:4220/assets/cover.png",
        "type": "image",
        "alt": "skills cover"
      }
    ],
    "links": [
      {
        "label": "主页",
        "url": "http://localhost:4220/shadow/server",
        "type": "website"
      }
    ],
    "publisher": {
      "name": "Shadow"
    }
  },
  "iframe": {
    "entry": "http://localhost:4220/shadow/server",
    "allowedOrigins": ["http://localhost:4220"]
  },
  "api": {
    "baseUrl": "http://localhost:4220",
    "auth": {
      "type": "oauth2-bearer"
    }
  },
  "access": {
    "defaultPermissions": ["skills.library:read"],
    "defaultApprovalMode": "none"
  },
  "commands": [
    {
      "name": "skills.list",
      "title": "List skills",
      "description": "List reusable skills in this server skill library.",
      "path": "/api/shadow/commands/skills.list",
      "permission": "skills.library:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "maxLength": 120
          },
          "tag": {
            "type": "string",
            "maxLength": 40
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "skills.search",
      "title": "Search skills",
      "description": "Search the server skill library and indexed skills.sh snapshot.",
      "path": "/api/shadow/commands/skills.search",
      "permission": "skills.library:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "maxLength": 120
          },
          "tag": {
            "type": "string",
            "maxLength": 40
          },
          "limit": {
            "type": "number",
            "minimum": 1,
            "maximum": 100
          },
          "refresh": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "skills.get",
      "title": "Get skill",
      "description": "Read a skill definition and its command hints.",
      "path": "/api/shadow/commands/skills.get",
      "permission": "skills.library:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["skillId"],
        "properties": {
          "skillId": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "skills.snapshot",
      "title": "Snapshot skills directory",
      "description": "Refresh the public skills.sh snapshot used by this server skill library.",
      "path": "/api/shadow/commands/skills.snapshot",
      "permission": "skills.library:write",
      "action": "write",
      "dataClass": "server-private",
      "approvalMode": "first_time",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number",
            "minimum": 1,
            "maximum": 200
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "skills.download",
      "title": "Download skill zip",
      "description": "Download the complete skill as a zip package, including SKILL.md and supporting files.",
      "path": "/api/shadow/commands/skills.download",
      "permission": "skills.library:read",
      "action": "read",
      "dataClass": "server-private",
      "inputSchema": {
        "type": "object",
        "required": ["skillId"],
        "properties": {
          "skillId": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "skills.upload",
      "title": "Upload skill package",
      "description": "Upload a skill zip package or a standalone SKILL.md markdown file.",
      "path": "/api/shadow/commands/skills.upload",
      "input": "multipart",
      "permission": "skills.library:write",
      "action": "write",
      "dataClass": "server-private",
      "approvalMode": "first_time",
      "binary": {
        "supported": true,
        "field": "file",
        "maxBytes": 5242880,
        "contentTypes": [
          "application/zip",
          "application/x-zip-compressed",
          "text/markdown",
          "text/plain"
        ]
      },
      "inputSchema": {
        "type": "object",
        "required": ["filename", "contentBase64"],
        "properties": {
          "filename": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "contentType": {
            "type": "string",
            "maxLength": 120
          },
          "contentBase64": {
            "type": "string",
            "minLength": 1,
            "maxLength": 7000000
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "skills.install",
      "title": "Install skill",
      "description": "Dispatch an Inbox task asking a selected Buddy to download the skill zip and install it.",
      "path": "/api/shadow/commands/skills.install",
      "permission": "skills.library:write",
      "action": "write",
      "dataClass": "server-private",
      "approvalMode": "first_time",
      "inputSchema": {
        "type": "object",
        "required": ["skillId", "targetBuddyAgentId"],
        "properties": {
          "skillId": {
            "type": "string",
            "minLength": 1
          },
          "targetBuddyAgentId": {
            "type": "string",
            "minLength": 1
          },
          "targetBuddyUserId": {
            "type": "string",
            "minLength": 1
          },
          "targetBuddyLabel": {
            "type": "string",
            "maxLength": 120
          },
          "targetLabel": {
            "type": "string",
            "maxLength": 120
          }
        },
        "additionalProperties": false
      }
    }
  ],
  "skills": [
    {
      "name": "shadow-skill-library",
      "description": "Use when a Buddy needs to discover reusable skills, download a complete skill zip, upload a skill package, or install a skill through the Shadow Skills App.",
      "commandHints": [
        "shadow-skills skills.list",
        "shadow-skills skills.search",
        "shadow-skills skills.get",
        "shadow-skills skills.snapshot",
        "shadow-skills skills.download",
        "shadow-skills skills.upload",
        "shadow-skills skills.install"
      ]
    }
  ],
  "events": ["skills.updated"]
}

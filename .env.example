# Shadow (虾豆) Environment Variables Template
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────

# Database connection string (e.g. postgresql://user:pass@host:5432/dbname)
DATABASE_URL=

# Redis connection URL (e.g. redis://localhost:6379)
REDIS_URL=

# JWT signing secret — random string, min 32 chars
# Generate: openssl rand -hex 32
JWT_SECRET=

# MinIO object storage endpoint (hostname or IP, no protocol)
MINIO_ENDPOINT=

# MinIO access key (alphanumeric, min 3 chars)
MINIO_ACCESS_KEY=

# MinIO secret key (min 8 chars)
MINIO_SECRET_KEY=

# ── Server ────────────────────────────────────────────────────────────────

# Server port (default: 3002)
PORT=3002

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# JWT token expiry (default: 7d)
JWT_EXPIRES_IN=7d

# JWT refresh token expiry
# JWT_REFRESH_EXPIRES_IN=30d

# JWT agent token expiry
# JWT_AGENT_EXPIRES_IN=7d

# ── Database (used by docker-compose prod) ───────────────────────────────

# PostgreSQL user (default: shadow)
POSTGRES_USER=shadow

# PostgreSQL password — REQUIRED for production
POSTGRES_PASSWORD=

# PostgreSQL database name (default: shadow)
POSTGRES_DB=shadow

# ── MinIO ─────────────────────────────────────────────────────────────────

# MinIO port (default: 9000)
MINIO_PORT=9000

# Use SSL for MinIO connection (true/false, default: false)
MINIO_USE_SSL=false

# MinIO bucket name (default: shadow)
MINIO_BUCKET=shadow

# ── CORS ──────────────────────────────────────────────────────────────────

# Allowed CORS origin(s), comma-separated for multiple
# Example: http://localhost:3000,https://shadowob.app
CORS_ORIGIN=http://localhost:3000

# ── OAuth ─────────────────────────────────────────────────────────────────

# Public URL of the web app (e.g. http://localhost:3000 or https://shadowob.app)
# REQUIRED for production
OAUTH_BASE_URL=http://localhost:3000

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Admin Account ─────────────────────────────────────────────────────────

# Admin email (default: admin@shadowob.app)
ADMIN_EMAIL=admin@shadowob.app

# Admin username (default: admin)
ADMIN_USERNAME=admin

# Admin password — REQUIRED for production
ADMIN_PASSWORD=

# Development-only admin wallet grants (local/demo only)
ENABLE_DEV_TOPUP=0

# ── Stripe (only if accepting payments) ───────────────────────────────────

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloud / Kubernetes / Pulumi ───────────────────────────────────────────

# Master key used to encrypt BYOK kubeconfigs and other cloud secrets.
# Generate: openssl rand -hex 32
KMS_MASTER_KEY=

# Host path to the kubeconfig file mounted into server/cloud-worker containers.
# Example (macOS): /Users/yourname/.kube/config
# KUBECONFIG_HOST_PATH=

# In-container kubeconfig path used by docker-compose.
KUBECONFIG=/root/.kube/config

# Base64-encoded kubeconfig passed into deployed templates/agents that reference
# ${env:KUBECONFIG_B64}. Required for templates that use the kubernetes plugin
# inside the running agent itself, not just in the server/cloud-worker.
# KUBECONFIG_B64=

# Optional kubectl context override.
# KUBECONFIG_CONTEXT=

# Hostname used to rewrite localhost/127.0.0.1 entries inside kubeconfig files
# for container-to-host cluster access (Rancher Desktop, Colima, etc.).
KUBECONFIG_LOOPBACK_HOST=host.lima.internal

# URL that agent pods should use to call the Shadow server from inside the
# Kubernetes cluster. Keep SHADOW_SERVER_URL pointed at the Docker service
# (for worker-side provisioning), and use this value for the in-cluster runtime.
SHADOW_AGENT_SERVER_URL=http://host.lima.internal:3002

# Cloud worker poll interval in milliseconds.
# CLOUD_WORKER_POLL_INTERVAL_MS=5000

# Shared Pulumi config encryption passphrase for cloud deployments.
# REQUIRED for production cloud deployments.
# PULUMI_CONFIG_PASSPHRASE=

# ── Voice Enhance (AI voice enhancement feature) ──────────────────────────

VOICE_ENHANCE_ENABLED=false
# VOICE_ENHANCE_PROVIDER=openai
# VOICE_ENHANCE_BASE_URL=
# VOICE_ENHANCE_API_KEY=
# VOICE_ENHANCE_MODEL=gpt-4o-mini
# VOICE_ENHANCE_TEMPERATURE=0.7
# VOICE_ENHANCE_MAX_TOKENS=1000
# VOICE_ENHANCE_TIMEOUT=30

# ── Misc ──────────────────────────────────────────────────────────────────

# Log level (default: info)
# LOG_LEVEL=debug

# Custom migrations directory
# MIGRATIONS_DIR=./drizzle

# Server working directory
# SERVER_CWD=.

# Force DB push on startup (development only, default: false)
# DB_PUSH=true

# Node environment (development/production/test)
# NODE_ENV=production

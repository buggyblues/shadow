# Shadow (虾豆) Environment Variables Template
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────

# Database connection string (e.g. postgresql://user:pass@host:5432/dbname)
DATABASE_URL=

# Redis connection URL (e.g. redis://localhost:6379)
REDIS_URL=

# JWT signing secret — random string, min 32 chars
# Generate: openssl rand -hex 32
JWT_SECRET=

# MinIO object storage endpoint (hostname or IP, no protocol)
MINIO_ENDPOINT=

# MinIO access key (alphanumeric, min 3 chars)
MINIO_ACCESS_KEY=

# MinIO secret key (min 8 chars)
MINIO_SECRET_KEY=

# ── Production images (used by docker-compose.prod.yml) ──────────────────

# CI publishes these images via .github/workflows/publish-prod-images.yml.
# Use SHADOWOB_IMAGE_TAG=sha-<git-sha-prefix> for an immutable deploy/rollback,
# or leave it as latest to track the newest verified main build.
SHADOWOB_IMAGE_REGISTRY=ghcr.io
SHADOWOB_IMAGE_NAMESPACE=buggyblues
SHADOWOB_IMAGE_TAG=latest

# Cloud runner images default to the same registry, namespace, and tag as the
# main app images. Override these only when testing or rolling back runners
# independently from server/web/admin.
# SHADOWOB_RUNNER_IMAGE_REGISTRY=ghcr.io
# SHADOWOB_RUNNER_IMAGE_NAMESPACE=buggyblues
# SHADOWOB_RUNNER_IMAGE_TAG=latest
# SHADOWOB_OPENCLAW_RUNNER_IMAGE=
# SHADOWOB_CLAUDE_RUNNER_IMAGE=
# SHADOWOB_CODEX_RUNNER_IMAGE=
# SHADOWOB_OPENCODE_RUNNER_IMAGE=
# SHADOWOB_HERMES_RUNNER_IMAGE=

# ── Server ────────────────────────────────────────────────────────────────

# Disable all server-side request rate limits for local debugging.
# Also disables DIY Cloud's daily generation quota.
# Never enable in production.
SHADOWOB_DISABLE_RATE_LIMITS=false

# Server port (default: 3002)
PORT=3002

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Official community desktop. Use the same server slug or id for both values.
# Visitors are ensured as members of this server when listing their servers,
# and the web app uses it as the default authenticated community desktop entry.
# SHADOWOB_OFFICIAL_OS_SERVER=official
# VITE_SHADOW_OFFICIAL_OS_SERVER=official

# JWT token expiry (default: 7d)
JWT_EXPIRES_IN=7d

# JWT refresh token expiry
# JWT_REFRESH_EXPIRES_IN=30d

# JWT agent token expiry
# JWT_AGENT_EXPIRES_IN=7d

# ── Database (used by docker-compose prod) ───────────────────────────────

# PostgreSQL user (default: shadow)
POSTGRES_USER=shadow

# PostgreSQL password — REQUIRED for production
POSTGRES_PASSWORD=

# PostgreSQL database name (default: shadow)
POSTGRES_DB=shadow

# ── MinIO ─────────────────────────────────────────────────────────────────

# MinIO port (default: 9000)
MINIO_PORT=9000

# Use SSL for MinIO connection (true/false, default: false)
MINIO_USE_SSL=false

# MinIO bucket name (default: shadow)
MINIO_BUCKET=shadow

# ── CORS ──────────────────────────────────────────────────────────────────

# Allowed CORS origin(s), comma-separated for multiple
# Example: http://localhost:3000,https://shadowob.app
CORS_ORIGIN=http://localhost:3000

# ── OAuth ─────────────────────────────────────────────────────────────────

# Public URL of the web app (e.g. http://localhost:3000 or https://shadowob.app)
# REQUIRED for production
OAUTH_BASE_URL=http://localhost:3000

# Google OAuth credentials. GOOGLE_CLIENT_ID is used by the server to validate
# Google ID tokens and by the web app build to enable Chrome/FedCM prompts.
# Website login embeds the web app auth modal and does not consume this value.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email Login Codes ─────────────────────────────────────────────────────

# Production email code login requires one delivery channel.
# Option A: call an internal mailer/webhook with { to, code, locale }.
EMAIL_OTP_WEBHOOK_URL=

# Option B: send directly through Resend.
RESEND_API_KEY=
RESEND_FROM=Shadow <no-reply@mail.shadowob.com>

# Option C: send directly through SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Admin Account ─────────────────────────────────────────────────────────

# Admin email (default: admin@shadowob.app)
ADMIN_EMAIL=admin@shadowob.app

# Admin username (default: admin)
ADMIN_USERNAME=admin

# Admin password — REQUIRED for production
ADMIN_PASSWORD=

# Development-only admin wallet grants (local/demo only)
ENABLE_DEV_TOPUP=0

# ── Stripe (only if accepting payments) ───────────────────────────────────

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloud / Kubernetes / Pulumi ───────────────────────────────────────────

# Master key used to encrypt BYOK kubeconfigs and other cloud secrets.
# Generate: openssl rand -hex 32
KMS_MASTER_KEY=

# Host path to the kubeconfig file mounted into the server container.
# Example (macOS): /Users/yourname/.kube/config
# KUBECONFIG_HOST_PATH=

# Optional Web SaaS cluster.json target for docker-compose.
# Run `shadowob-cloud cluster init --config cluster.json` first, then set the
# host paths and the matching in-container paths below.
# CLOUD_SAAS_CLUSTER_CONFIG_HOST_PATH=/Users/yourname/cluster.json
# CLOUD_SAAS_CLUSTER_CONFIG=/app/cluster.json
# CLOUD_SAAS_CLUSTER_KUBECONFIG_HOST_PATH=/Users/yourname/.shadow-cloud/clusters/prod.yaml
# CLOUD_SAAS_CLUSTER_KUBECONFIG=/home/node/.shadow-cloud/clusters/prod.yaml
# Vanilla k3s clusters should use standard Deployment resources. Set to
# agent-sandbox only after installing the SandboxTemplate/SandboxClaim CRDs and controller.
CLOUD_SAAS_WORKLOAD_BACKEND=deployment

# Cloud Computer repair images. Direct local development needs these just like
# Docker Compose does; without them Browser/Desktop can only attach to an
# already-compatible in-cluster Service and cannot repair stale runtimes.
CLOUD_COMPUTER_BROWSER_IMAGE=mcr.microsoft.com/playwright:v1.59.1-noble
CLOUD_COMPUTER_BROWSER_PROFILE_STORAGE_CLASS=standard
CLOUD_COMPUTER_DESKTOP_IMAGE=dorowu/ubuntu-desktop-lxde-vnc:latest

# In-container kubeconfig path used by docker-compose.
KUBECONFIG=/root/.kube/config

# Base64-encoded kubeconfig passed into deployed templates/agents that reference
# ${env:KUBECONFIG_B64}. Required for templates that use the kubernetes plugin
# inside the running agent itself, not just in the server.
# KUBECONFIG_B64=

# Optional kubectl context override.
# KUBECONFIG_CONTEXT=

# Hostname used to rewrite localhost/127.0.0.1 entries inside kubeconfig files
# for container-to-host cluster access (Rancher Desktop, Colima, etc.).
KUBECONFIG_LOOPBACK_HOST=host.lima.internal

# URL that agent pods should use to call the Shadow server from inside the
# Kubernetes cluster. Keep SHADOWOB_SERVER_URL pointed at the Docker service
# (for in-server deployment provisioning), and use this value for the in-cluster runtime.
# `host.lima.internal` is for local Rancher Desktop/Colima only; production should set
# this to an in-cluster service URL or other address reachable from agent pods.
SHADOWOB_AGENT_SERVER_URL=http://host.lima.internal:3002

# Local Space App command allowlist. Keep empty in production. For local
# integrations served from the host while the Shadow server runs in Docker/Lima:
# SHADOWOB_SPACE_APP_ALLOW_PRIVATE_HOSTS=localhost,127.0.0.1,host.docker.internal,host.lima.internal

# Official model proxy. Upstream provider credentials stay on the server and are never
# injected into Cloud templates or pods. One-click plays receive only a limited smp_ token.
SHADOWOB_MODEL_PROXY_ENABLED=true
SHADOWOB_MODEL_PROXY_MODEL=deepseek-v4-flash
# Explicit pod-reachable Shadow URL for local/private clusters. Unlike the inferred URL,
# internal service and host bridge names are accepted here because the operator opted in.
# Never use localhost: it resolves inside the Buddy pod.
# SHADOWOB_MODEL_PROXY_RUNTIME_SERVER_URL=http://host.lima.internal:3002
SHADOWOB_MODEL_PROXY_UPSTREAM_BASE_URL=https://api.deepseek.com
# SHADOWOB_MODEL_PROXY_UPSTREAM_API_KEY=
# Billing defaults: 1 CNY = 20 Shrimp Coins, with 0.02 / 1 / 2 CNY
# per million cached input, uncached input, and output tokens.
SHADOWOB_MODEL_PROXY_SHRIMP_PER_CNY=20
SHADOWOB_MODEL_PROXY_INPUT_CACHE_HIT_CNY_PER_MILLION=0.02
SHADOWOB_MODEL_PROXY_INPUT_CACHE_MISS_CNY_PER_MILLION=1
SHADOWOB_MODEL_PROXY_OUTPUT_CNY_PER_MILLION=2
# Legacy token-ratio billing is only used when explicitly enabled.
# SHADOWOB_MODEL_PROXY_BILLING_MODE=token_ratio
# SHADOWOB_MODEL_PROXY_TOKENS_PER_SHRIMP=1000
# SHADOWOB_MODEL_PROXY_INPUT_TOKENS_PER_SHRIMP=1000
# SHADOWOB_MODEL_PROXY_OUTPUT_TOKENS_PER_SHRIMP=500
# Embedded cloud deployment processor poll interval in milliseconds.
# CLOUD_WORKER_POLL_INTERVAL_MS=5000

# ── Voice Channels (Agora RTC) ────────────────────────────────────────────

# Server-only Agora credentials. The web app does not read VITE_AGORA_* values;
# authenticated voice joins receive limited RTC credentials from the API.
# AGORA_APP_ID=
# AGORA_APP_CERTIFICATE=

# Optional: disable embedded cloud deployment processor.
# ENABLE_CLOUD_DEPLOYMENT_PROCESSOR=true

# Shared Pulumi config encryption passphrase for cloud deployments.
# REQUIRED for production cloud deployments.
# PULUMI_CONFIG_PASSPHRASE=

# ── Voice Enhance (AI voice enhancement feature) ──────────────────────────

VOICE_ENHANCE_ENABLED=false
# VOICE_ENHANCE_PROVIDER=openai
# VOICE_ENHANCE_BASE_URL=
# VOICE_ENHANCE_API_KEY=
# VOICE_ENHANCE_MODEL=gpt-4o-mini
# VOICE_ENHANCE_TEMPERATURE=0.7
# VOICE_ENHANCE_MAX_TOKENS=1000
# VOICE_ENHANCE_TIMEOUT=30

# ── Misc ──────────────────────────────────────────────────────────────────

# Log level (default: info)
# LOG_LEVEL=debug

# Custom migrations directory
# MIGRATIONS_DIR=./drizzle

# Server working directory
# SERVER_CWD=.

# Force DB push on startup (development only, default: false)
# DB_PUSH=true

# Node environment (development/production/test)
# NODE_ENV=production
